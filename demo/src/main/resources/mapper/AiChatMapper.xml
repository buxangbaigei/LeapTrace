<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.AiChatMapper">

    <insert id="insert" parameterType="com.example.demo.entity.AiChat" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO ai_chat_log (user_id, role, content, created_at)
        VALUES (#{userId}, #{role}, #{content}, #{createdAt})
    </insert>

    <select id="selectById" resultType="com.example.demo.entity.AiChat">
        SELECT * FROM ai_chat_log WHERE id = #{id}
    </select>

    <select id="selectByUserIdWithPagination" resultType="com.example.demo.entity.AiChat">
        SELECT * FROM ai_chat_log
        WHERE user_id = #{userId}
        ORDER BY created_at DESC
        LIMIT #{offset}, #{limit}
    </select>
</mapper>

