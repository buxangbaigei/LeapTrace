<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.FoodLibMapper">

    <select id="selectByName" resultType="com.example.demo.entity.FoodLib">
        SELECT * FROM h_food_lib WHERE name = #{name}
    </select>

    <select id="searchByName" resultType="com.example.demo.entity.FoodLib">
        SELECT * FROM h_food_lib WHERE name LIKE CONCAT('%', #{keyword}, '%') AND is_common = 1
        ORDER BY name
        LIMIT 20
    </select>

    <select id="selectById" resultType="com.example.demo.entity.FoodLib">
        SELECT * FROM h_food_lib WHERE id = #{id}
    </select>
</mapper>
