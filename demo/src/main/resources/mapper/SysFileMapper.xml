<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.SysFileMapper">

    <insert id="insert" parameterType="com.example.demo.entity.SysFile" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_file (user_id, file_url, file_type, created_at)
        VALUES (#{userId}, #{fileUrl}, #{fileType}, #{createdAt})
    </insert>

    <select id="selectById" resultType="com.example.demo.entity.SysFile">
        SELECT * FROM sys_file WHERE id = #{id}
    </select>
</mapper>
